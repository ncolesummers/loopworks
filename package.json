{
  "name": "loopworks",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "dev:fixture": "LOOPWORKS_AUTH_BYPASS=true next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "agent-docs:sync": "bun run scripts/sync-agent-docs.ts --write",
    "agent-docs:check": "bun run scripts/sync-agent-docs.ts --check",
    "markdownlint": "markdownlint-cli2",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "review:ui": "bun run scripts/review-ui.mjs",
    "precommit": "bun run validate",
    "precommit:install": "uvx prek install",
    "precommit:run": "uvx prek run --all-files",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed-demo-data.ts",
    "db:seed:reset": "bun run scripts/seed-demo-data.ts --reset",
    "github:webhook-fixture": "bun run scripts/github-webhook-fixture.ts",
    "validate": "bun run format:check && bun run lint && bun run agent-docs:check && bun run markdownlint && bun run typecheck && bun run test && bun run storybook:build && bun run test:e2e"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@octokit/app": "^16.0.0",
    "@octokit/rest": "^22.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vercel/sdk": "^1.28.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "eve": "^0.11.7",
    "lucide-react": "^0.561.0",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@biomejs/biome": "^2.3.7",
    "@electric-sql/pglite": "^0.5.3",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/nextjs": "^10.4.6",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.3.0",
    "just-bash": "^3.0.2",
    "markdownlint-cli2": "^0.22.1",
    "postcss": "^8.5.6",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.14"
}
