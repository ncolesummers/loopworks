{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopworks.local/schemas/loop-manifest.schema.json",
  "title": "Loop Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "note",
    "loopStates",
    "requiredMetadata",
    "milestones",
    "labels",
    "agentReady"
  ],
  "properties": {
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
    },
    "note": {
      "type": "string",
      "minLength": 1
    },
    "loopStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "intake",
          "triage",
          "planned",
          "in_progress",
          "waiting_on_review",
          "validating",
          "blocked",
          "done"
        ]
      }
    },
    "requiredMetadata": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["repo", "milestone", "area", "priority", "state", "last_synced_at", "source_links"]
      }
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "name", "description", "personaTestIds", "issues"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^M\\d+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "personaTestIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "P01",
                "P02",
                "P03",
                "P04",
                "M01",
                "M02",
                "M03",
                "A01",
                "A02",
                "A03",
                "R01",
                "R02",
                "S01",
                "S02",
                "S03",
                "S04"
              ]
            }
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "labels", "template", "personaTestIds"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "labels": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "template": {
                  "type": "string",
                  "minLength": 1
                },
                "personaTestIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "enum": [
                      "P01",
                      "P02",
                      "P03",
                      "P04",
                      "M01",
                      "M02",
                      "M03",
                      "A01",
                      "A02",
                      "A03",
                      "R01",
                      "R02",
                      "S01",
                      "S02",
                      "S03",
                      "S04"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "category"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "enum": ["kind", "priority", "area", "status", "milestone", "custom"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "agentReady": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readyLabels",
        "blockedLabels",
        "requiredLabelPrefixes",
        "requiresMilestone",
        "requiresBody"
      ],
      "properties": {
        "readyLabels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockedLabels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredLabelPrefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiresMilestone": {
          "type": "boolean"
        },
        "requiresBody": {
          "type": "boolean"
        }
      }
    }
  }
}
